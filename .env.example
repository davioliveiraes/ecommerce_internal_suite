# ============================================
# BACKEND (Django) — copiar para backend/.env
# ============================================

# Django core
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database
# Em dev (SQLite), deixe comentado — o default usa BASE_DIR/db.sqlite3 (caminho absoluto).
# Em prod (PostgreSQL), defina explicitamente:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATABASE_URL=

# CORS — origens permitidas para o frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Timezone
TIME_ZONE=America/Fortaleza
LANGUAGE_CODE=pt-br

# ============================================
# FRONTEND (Vite) — copiar para frontend/.env
# ============================================

# Endpoint da API do backend Django
VITE_API_BASE_URL=http://localhost:8000/api
