# ============================================
# BACKEND (Django) — copiar para backend/.env
# ============================================

# Django core
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database
# Rodando manage.py direto na máquina host, use localhost.
# Dentro do Docker Compose, o docker-compose.yml sobrescreve para host `db`.
# Para usar SQLite em dev, deixe DATABASE_URL comentado.
DATABASE_URL=postgres://ibeize:ibeize@localhost:5432/ibeize

# CORS — origens permitidas para o frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Autenticação simples via token bearer assinado (12h por padrão)
AUTH_TOKEN_MAX_AGE_SECONDS=43200

# Timezone
TIME_ZONE=America/Fortaleza
LANGUAGE_CODE=pt-br

# ============================================
# FRONTEND (Vite) — copiar para frontend/.env
# ============================================

# Endpoint da API do backend Django
VITE_API_BASE_URL=http://localhost:8000/api

# ============================================
# POSTGRES (Docker Compose) — copiar para .env na raiz
# ============================================
POSTGRES_DB=ibeize
POSTGRES_USER=ibeize
POSTGRES_PASSWORD=ibeize
